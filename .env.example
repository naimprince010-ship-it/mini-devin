# ============================================================
# Plodder environment configuration
# Copy this file to .env and fill in your values
# ============================================================

# ─── LLM Configuration (Required — at least one provider) ──
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=
OPENAI_ENABLED=true

# Anthropic (Claude models — optional)
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
ANTHROPIC_ENABLED=false

# Ollama (Local models — optional)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_ENABLED=false

# Azure OpenAI (optional)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_NAME=
AZURE_ENABLED=false

# ─── Run Mode ────────────────────────────────────────────────
# offline | browse | interactive
RUN_MODE=browse

# ─── Browser Search API Keys (optional) ─────────────────────
TAVILY_API_KEY=
SERPAPI_API_KEY=

# ─── Browser Automation (optional) ───────────────────────────
# Option A: Browserless.io remote Chromium (no install needed, works in production)
# Get free API key at: https://browserless.io
BROWSERLESS_API_KEY=
# Option B: Self-hosted Browserless WebSocket URL
BROWSERLESS_WS_URL=
# If neither is set, falls back to local Playwright (requires: playwright install chromium)

# ─── GitHub Integration (optional) ──────────────────────────
GITHUB_TOKEN=
# Session "Working directory": paste https://github.com/org/repo → server runs git clone (private: needs token)
# GIT_CLONE_TIMEOUT_SEC=240

# ─── Safety Configuration ───────────────────────────────────
MAX_ITERATIONS=50
MAX_REPAIR_ITERATIONS=3
ALLOW_DEPENDENCY_BUMP=false
MAX_LINES_EDIT=300
MAX_FILES_DELETE=1

# ─── Workspace ──────────────────────────────────────────────
WORKSPACE_DIR=./workspace
RUNS_DIR=./runs
ARTIFACT_DIR=/workspace/runs

# ─── Database (for Docker deployment) ───────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=plodder

# ─── Resource Limits (Docker) ───────────────────────────────
CPU_LIMIT=2.0
MEMORY_LIMIT=4G

# ─── Agent code sandbox (terminal runs in sandbox when enabled) ──
# docker = local Docker (default). e2b = E2B cloud (needs pip extra: poetry install -E sandbox-e2b)
SANDBOX_BACKEND=docker
E2B_API_KEY=
# Optional custom E2B template; empty = default sandbox image
E2B_SANDBOX_TEMPLATE=
# Workspace sync limits for E2B (files uploaded on sandbox start)
# E2B_SYNC_MAX_FILES=400
# E2B_SYNC_MAX_FILE_BYTES=524288
# E2B_SANDBOX_TIMEOUT=600

# ─── IDE / LSP-style diagnostics (Monaco) ───────────────────
# Install: poetry install -E lsp-python  (basedpyright) or put pyright on PATH
# PYRIGHT_CMD=  # optional override, e.g. "basedpyright" or path to pyright
# PYRIGHT_TIMEOUT=90
# TSC_TIMEOUT=120   # npx tsc for .ts/.tsx

# ─── Logging ────────────────────────────────────────────────
VERBOSE=true

# ─── Self-improvement / teacher (optional, OpenAI-first) ────
# After each agent run, call a second model to critique the outcome and append JSONL for later SFT/DPO.
TEACHER_REVIEW_ENABLED=false
TEACHER_BACKEND=openai
TEACHER_MODEL=gpt-4o
# TEACHER_API_KEY=   # optional; defaults to OPENAI_API_KEY
# TRAINING_DATA_LOG_PATH=data/training_logs/reviews.jsonl  # relative to process cwd unless absolute
# TEACHER_MAX_EXCERPT_MESSAGES=32
# TEACHER_MAX_CHARS_PER_MESSAGE=6000

# Training / commercial provenance (not legal advice — align with your counsel + user ToS)
# TRAINING_RIGHTS_BASIS=first_party_mini_devin_sessions_review_with_teacher_model
# TRAINING_COMMERCIAL_OK=true

# ─── Knowledge stack (RAG + prompts; no weight training) ─────
# Optional global corpus: build with scripts/ingest_global_corpus.py — see docs/GLOBAL_CORPUS.md
# GLOBAL_RAG_ENABLED=false
# MINI_DEVIN_GLOBAL_CORPUS_PATH=   # default: ~/.mini-devin/global_corpus/vector_store.json
# GLOBAL_RAG_OPENAI_EMBEDDINGS=false   # set true + OPENAI_API_KEY for OpenAI embeddings on corpus only
# GLOBAL_RAG_TOP_K=8
# GLOBAL_RAG_MAX_CHARS=8000

# Curated few-shot JSONL (default: data/golden/examples.jsonl)
# GOLDEN_DATA_PATH=
# GOLDEN_MAX_RECORDS=8
# GOLDEN_MAX_CHARS=6000

# Append focused rules to system prompt: default | clean_code | performance | security
# AGENT_SPECIALIZATION=default

# ─── Observability (optional; add when you integrate) ───────
# LangSmith (LangChain): LANGCHAIN_TRACING_V2=true, LANGCHAIN_API_KEY=...
# LangFuse: self-host and set keys per their docs

# ─── DigitalOcean App Platform (see .do/app.yaml) ─────────────
# In DO: App → Settings → App-Level Environment Variables (mark secrets as ENCRYPTED).
# Required for default models:
#   OPENAI_API_KEY
# Recommended / optional:
#   LLM_MODEL=gpt-4o-mini
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db   (or leave sqlite for single-instance)
#   BROWSERLESS_API_KEY, BROWSERLESS_WS_URL
#   GITHUB_TOKEN
#   ANTHROPIC_API_KEY, GEMINI_API_KEY or GOOGLE_API_KEY (if you extend app env)
# After deploy, run:  pwsh ./scripts/smoke_deploy.ps1
# Or:  $env:SMOKE_BASE_URL='https://your-app.ondigitalocean.app'; ./scripts/smoke_deploy.ps1

# ─── Railway (service → Variables tab; mark secrets as Secret) ─────────
# Do NOT add a custom "PORT" variable — Railway injects PORT. A duplicate or pasted multiline
# PORT breaks listen vs public target port and causes 502. Networking → target port = that PORT.
# Minimum (you likely have these already):
#   OPENAI_API_KEY          (Secret)
#   LLM_MODEL=gpt-4o-mini
# Optional — strongly recommended for stable deploys / fewer surprises:
#   PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
#   GIT_PYTHON_REFRESH=quiet
#   PYTHONIOENCODING=UTF-8
#   RUN_MODE=browse
#   LLM_TEMPERATURE=0.1
# Optional — production auth (same value across restarts / replicas):
#   JWT_SECRET=<long random string>   (Secret)
# Optional — Postgres: add a Railway PostgreSQL service, open it → Variables → copy DATABASE_URL
#   into this app service (or use Variable Reference). Plain postgresql:// or postgres:// works;
#   the app normalizes to postgresql+asyncpg:// automatically.
#   DATABASE_SSL_REQUIRE=1   if Postgres needs TLS but the URL has no sslmode (asyncpg needs explicit ssl)
#   DATABASE_CONNECT_TIMEOUT=15   seconds to establish each asyncpg connection (default 15)
#   DATABASE_INIT_TIMEOUT=120   seconds cap for first-time create_all during background startup
#   VERIFICATION_BLOCKING_LINT=1   Auto-verify: treat lint failure as blocking (default: WARNING — no rollback on lint only)
# Optional — browser tools without local Chromium in the container:
#   BROWSERLESS_API_KEY   (Secret)   or   BROWSERLESS_WS_URL=wss://...
# Optional — GitHub repos / API:
#   GITHUB_TOKEN   (Secret)
# Other providers (only if you use them):
#   ANTHROPIC_API_KEY, GEMINI_API_KEY or GOOGLE_API_KEY, AZURE_* , OLLAMA_*
# Search in agent browser tools:
#   TAVILY_API_KEY or SERPAPI_API_KEY
# E2B cloud sandbox (poetry install -E sandbox-e2b):
#   E2B_API_KEY

# ─── Project memory: ingest whole repo into long-term context (optional) ───────
# POST /api/projects/{project_id}/ingest-repo  JSON examples:
#   {"repo_path":"/abs/path/on/server"}  or  {"repo_url":"https://github.com/org/repo.git"}
#   Preview only: add "dry_run": true  |  Same snapshot twice skipped unless "skip_if_duplicate": false
#   optional "keep_clone": true after URL clone
# Paths must be under ../agent-workspace (session clones), this checkout, or:
# REPO_INGEST_EXTRA_ROOT=
# Create sessions with the same project_id to inject that memory into the agent.

# ─── Local bridge (optional — run agent terminal on the developer's machine) ──
# Server: set a long random secret. Mint token: POST /api/sessions/{id}/bridge/token
#   with header X-Plodder-Bridge-Secret: <same value> (legacy: X-MiniDevin-Bridge-Secret).
#   Client: poetry run plodder ...  or  poetry run python -m mini_devin.bridge.local_runner
#   --api-base https://your-host/app/api --session-id <uuid> --secret <same>
# Treat BRIDGE_ISSUE_SECRET like a password — anyone with it can attach a bridge to any session.
# BRIDGE_ISSUE_SECRET=
