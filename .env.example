# ============================================================
# Mini-Devin Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ─── LLM Configuration (Required — at least one provider) ──
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=
OPENAI_ENABLED=true

# Anthropic (Claude models — optional)
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
ANTHROPIC_ENABLED=false

# Ollama (Local models — optional)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_ENABLED=false

# Azure OpenAI (optional)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_NAME=
AZURE_ENABLED=false

# ─── Run Mode ────────────────────────────────────────────────
# offline | browse | interactive
RUN_MODE=browse

# ─── Browser Search API Keys (optional) ─────────────────────
TAVILY_API_KEY=
SERPAPI_API_KEY=

# ─── Browser Automation (optional) ───────────────────────────
# Option A: Browserless.io remote Chromium (no install needed, works in production)
# Get free API key at: https://browserless.io
BROWSERLESS_API_KEY=
# Option B: Self-hosted Browserless WebSocket URL
BROWSERLESS_WS_URL=
# If neither is set, falls back to local Playwright (requires: playwright install chromium)

# ─── GitHub Integration (optional) ──────────────────────────
GITHUB_TOKEN=

# ─── Safety Configuration ───────────────────────────────────
MAX_ITERATIONS=50
MAX_REPAIR_ITERATIONS=3
ALLOW_DEPENDENCY_BUMP=false
MAX_LINES_EDIT=300
MAX_FILES_DELETE=1

# ─── Workspace ──────────────────────────────────────────────
WORKSPACE_DIR=./workspace
RUNS_DIR=./runs
ARTIFACT_DIR=/workspace/runs

# ─── Database (for Docker deployment) ───────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=minidevin

# ─── Resource Limits (Docker) ───────────────────────────────
CPU_LIMIT=2.0
MEMORY_LIMIT=4G

# ─── Agent code sandbox (terminal runs in sandbox when enabled) ──
# docker = local Docker (default). e2b = E2B cloud (needs pip extra: poetry install -E sandbox-e2b)
SANDBOX_BACKEND=docker
E2B_API_KEY=
# Optional custom E2B template; empty = default sandbox image
E2B_SANDBOX_TEMPLATE=
# Workspace sync limits for E2B (files uploaded on sandbox start)
# E2B_SYNC_MAX_FILES=400
# E2B_SYNC_MAX_FILE_BYTES=524288
# E2B_SANDBOX_TIMEOUT=600

# ─── Logging ────────────────────────────────────────────────
VERBOSE=true
