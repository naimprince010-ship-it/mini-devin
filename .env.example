# ============================================================
# Mini-Devin Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ─── LLM Configuration (Required — at least one provider) ──
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=
OPENAI_ENABLED=true

# Anthropic (Claude models — optional)
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
ANTHROPIC_ENABLED=false

# Ollama (Local models — optional)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_ENABLED=false

# Azure OpenAI (optional)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_NAME=
AZURE_ENABLED=false

# ─── Run Mode ────────────────────────────────────────────────
# offline | browse | interactive
RUN_MODE=browse

# ─── Browser Search API Keys (optional) ─────────────────────
TAVILY_API_KEY=
SERPAPI_API_KEY=

# ─── Browser Automation (optional) ───────────────────────────
# Option A: Browserless.io remote Chromium (no install needed, works in production)
# Get free API key at: https://browserless.io
BROWSERLESS_API_KEY=
# Option B: Self-hosted Browserless WebSocket URL
BROWSERLESS_WS_URL=
# If neither is set, falls back to local Playwright (requires: playwright install chromium)

# ─── GitHub Integration (optional) ──────────────────────────
GITHUB_TOKEN=

# ─── Safety Configuration ───────────────────────────────────
MAX_ITERATIONS=50
MAX_REPAIR_ITERATIONS=3
ALLOW_DEPENDENCY_BUMP=false
MAX_LINES_EDIT=300
MAX_FILES_DELETE=1

# ─── Workspace ──────────────────────────────────────────────
WORKSPACE_DIR=./workspace
RUNS_DIR=./runs
ARTIFACT_DIR=/workspace/runs

# ─── Database (for Docker deployment) ───────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=minidevin

# ─── Resource Limits (Docker) ───────────────────────────────
CPU_LIMIT=2.0
MEMORY_LIMIT=4G

# ─── Logging ────────────────────────────────────────────────
VERBOSE=true

# ─── DigitalOcean App Platform (see .do/app.yaml) ─────────────
# In DO: App → Settings → App-Level Environment Variables (mark secrets as ENCRYPTED).
# Required for default models:
#   OPENAI_API_KEY
# Recommended / optional:
#   LLM_MODEL=gpt-4o-mini
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db   (or leave sqlite for single-instance)
#   BROWSERLESS_API_KEY, BROWSERLESS_WS_URL
#   GITHUB_TOKEN
#   ANTHROPIC_API_KEY, GEMINI_API_KEY or GOOGLE_API_KEY (if you extend app env)
# After deploy, run:  pwsh ./scripts/smoke_deploy.ps1
# Or:  $env:SMOKE_BASE_URL='https://your-app.ondigitalocean.app'; ./scripts/smoke_deploy.ps1
