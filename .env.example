# ============================================
# Mini-Devin Configuration
# Copy this file to .env and fill in your keys
# ============================================

# ─── LLM API Keys (at least one required) ─────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=        # optional
LLM_MODEL=gpt-4o          # gpt-4o | gpt-4o-mini | claude-3-5-sonnet-20241022

# ─── GitHub Integration (optional) ────────────────────────────
GITHUB_TOKEN=             # Personal access token for auto-commit/push

# ─── Browser Search (optional) ────────────────────────────────
TAVILY_API_KEY=           # tavily.com — for web search
SERPAPI_API_KEY=          # serpapi.com — alternative search

# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=minidevin

# ─── Workspace ────────────────────────────────────────────────
WORKSPACE_DIR=./workspace  # Where agent projects are created
RUNS_DIR=./runs            # Where agent run artifacts are stored

# ─── Agent Limits ─────────────────────────────────────────────
MAX_ITERATIONS=50
LLM_TEMPERATURE=0.1

# ─── Resource Limits (Docker) ─────────────────────────────────
CPU_LIMIT=2.0
MEMORY_LIMIT=4G
