# ============================================================
# Plodder environment configuration
# Copy this file to .env and fill in your values
# ============================================================

# ─── LLM Configuration (Required — at least one provider) ──
# Primary stack: Groq (OpenAI-compatible API via LiteLLM: ``groq/<model_id>``). Set GROQ_API_KEY below.
# Override default model with LLM_MODEL (registry id, e.g. llama-3.3-70b-versatile, or groq/...).
# Groq free-tier picks (see https://console.groq.com/docs/deprecations ): llama-3.3-70b-versatile (main agent),
# llama-3.1-8b-instant (fast), mixtral-8x7b-32768 (MoE). Legacy llama3-*-8192 IDs remap automatically.
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
# OpenHands-style: fast model for tool-error retries and forced tool nudges (terminal/browser/editor diagnostics).
LLM_MODEL_OBSERVATION=llama-3.1-8b-instant
LLM_OBSERVATION_TEMPERATURE=0.1
# Groq free tier TPM is low (~12k/min on-demand); keep completions small (raise on Dev/paid tier).
LLM_MAX_OUTPUT_TOKENS=4096
# Optional hard ceiling beyond LLM_MAX_OUTPUT_TOKENS (default 8192 for Groq only).
# GROQ_MAX_OUTPUT_TOKENS_CAP=8192
# Tighter chat window for Groq when LLM_MAX_HISTORY_MESSAGES is unset (default 36 for Groq).
# LLM_MAX_HISTORY_MESSAGES_GROQ=24
# LiteLLM HTTP timeout seconds (Groq defaults to 120s in code when unset — fast provider; raise for huge completions).
LLM_TIMEOUT_SEC=120
# Production resiliency knobs for transient 429/5xx errors
# Retry attempts per model candidate
LLM_API_MAX_ATTEMPTS=5
# Base delay in seconds (effective delay is exponential: base, 2x, 4x, ...)
LLM_API_RETRY_DELAY_SECONDS=2
# Upper bound for each retry wait
LLM_API_RETRY_MAX_DELAY_SECONDS=30
# Random jitter added to each retry wait to avoid synchronized retry storms
LLM_API_RETRY_JITTER_SECONDS=0.5
# Cap concurrent outbound LLM calls across the process (set 0 to disable)
LLM_API_MAX_CONCURRENCY=8
# Tail-trimmed chat window sent per request. Lower = fewer prompt tokens per call.
LLM_MAX_HISTORY_MESSAGES=60
# Long-context condenser: summarize the middle; keeps initial goal + last N tool observations verbatim.
LLM_CONTEXT_CONDENSER=true
LLM_CONDENSE_MIN_MESSAGES=20
LLM_CONDENSE_MIN_CHARS=40000
LLM_CONDENSE_LAST_OBSERVATIONS=3
# Gemini safety override in LiteLLM (BLOCK_NONE on core categories). Set false to use provider defaults.
LLM_GEMINI_SAFETY_BLOCK_NONE=true
# Prompt caching: mark the system prompt as a cache breakpoint for Claude-family models so
# repeated turns reuse system+tools at a large discount. No-op for OpenAI/DeepSeek (auto-cached).
LLM_PROMPT_CACHE=true
# Injected into every agent completion (not stored in session JSON): PLAN.md + last editor focus file.
# Caps are per-call char limits; keep small to save tokens (agent can `editor read_file` for more).
PLODDER_PLAN_MD_MAX_CHARS=8000
PLODDER_CONTEXT_FILE_MAX_CHARS=16000
# Focus-file injection mode: 'eager' inlines the file (head+tail, capped) each turn;
# 'lazy' sends only a pointer so the agent reads it on demand via editor read_file (fewest tokens).
PLODDER_FOCUS_FILE_MODE=eager
# Token-saver: when PLAN.md / focus file is unchanged from the previous model call, send only a
# compact head + pointer instead of the full body. Set false to always resend full content.
PLODDER_EPHEMERAL_DEDUP=true
# Task-prompt compaction: for very large user prompts, send a compacted version to the LLM
# while preserving the full original task in session data/history.
PLODDER_TASK_PROMPT_COMPACT=true
PLODDER_TASK_PROMPT_COMPACT_MAX_CHARS=1200
# Acceptance criteria caps for prompt efficiency.
PLODDER_TASK_CRITERIA_MAX_ITEMS=8
PLODDER_TASK_CRITERION_MAX_CHARS=220
# Anti-loop guard: after this many consecutive read-only inspections (dir/ls/git status/PLAN.md read)
# with no file change, the agent gets a nudge to take a real action.
PLODDER_PROGRESS_GUARD_AFTER_INSPECTIONS=2
# Escalating hard-stop: after the progress guard fires this many times without any real progress,
# end the run (BLOCKED) instead of looping forever and wasting tokens. 0 disables the hard-stop.
PLODDER_PROGRESS_GUARD_HARD_STOP=3

# Groq (https://console.groq.com — create an API key; do not commit real keys)
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_ENABLED=true
# Optional default when multiple providers are configured (otherwise first configured wins; Groq is checked first).
# DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (Google AI Studio — LiteLLM: gemini/gemini-2.0-flash). Optional: GEMINI_FLASH_SUCCESSOR_MODEL=...
GEMINI_API_KEY="YOUR_KEY_HERE"
# Optional alias some tools read:
# GOOGLE_API_KEY=
GOOGLE_AI_ENABLED=true

# -----------------------------------------------------------------------------
# Ollama Configuration (Local models)
# -----------------------------------------------------------------------------
# For Docker/production, use http://host.docker.internal:11434
# For local running without Docker, use http://localhost:11434
OLLAMA_API_BASE=http://host.docker.internal:11434  # Ollama server URL
OLLAMA_ENABLED=true                     # Enable/disable Ollama provider

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=
OPENAI_ENABLED=true

# Enterprise routing policy (strict separation: chat vs benchmark model scopes)
STRICT_MODEL_ROUTING=true
CHAT_MODEL_ALLOWLIST=auto,openai/qwen3-coder-flash
CHAT_MODEL_DENYLIST=openai/gpt-5.3-codex
BENCHMARK_MODEL_ALLOWLIST=openai/gpt-5.3-codex,openai/qwen3-coder-flash
BENCHMARK_MODEL_DENYLIST=
BENCHMARK_DEFAULT_MODEL=openai/gpt-5.3-codex

# Benchmark quality-loop tuning
CODE_BENCH_BEST_OF=3
CODE_BENCH_REPAIR_ATTEMPTS=4

# Structured exam-to-chat knowledge transfer
BENCHMARK_TRANSFER_TO_CHAT=true
BENCHMARK_KNOWLEDGE_INJECTION=true
BENCHMARK_LESSONS_DIR=knowledge_base
BENCHMARK_LESSONS_PATH=knowledge_base/benchmark_lessons.md
BENCHMARK_LESSONS_MAX_CHARS=8000

# Optional pricing map for dashboard script
# BENCHMARK_MODEL_PRICE_PER_1K_OUTPUT_TOKENS=openai/qwen3-coder-flash=0.0003,openai/gpt-5.3-codex=0.015

# Anthropic (Claude models — optional)
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
ANTHROPIC_ENABLED=false

# Ollama (local or remote server — optional)
# Remote example (DigitalOcean): http://68.183.92.70:11434
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_ENABLED=false

# Azure OpenAI (optional)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_NAME=
AZURE_ENABLED=false

# ─── Run Mode ────────────────────────────────────────────────
# offline | browse | interactive
RUN_MODE=browse

# ─── Event backbone (OpenHands-style Action → Observation bus) ──
# run_simple() always starts AgentController + stream. Full Agent.run() also uses the
# stream when PLODDER_BACKBONE_FOR_RUN is enabled (try/finally teardown).
# PLODDER_BACKBONE_FOR_RUN=false
# PLODDER_BACKBONE_HOST_RUNTIME=true   # false = LocalRuntime (registry tool.execute only; no sandbox shim)
# PLODDER_BACKBONE_TOOL_TIMEOUT=600
# PLODDER_DOCKER_RUNTIME_IMAGE=python:3.11-slim   # used by DockerRuntime for CmdRunAction / terminal-in-docker

# ─── Browser Search API Keys (optional) ─────────────────────
TAVILY_API_KEY=
SERPAPI_API_KEY=

# ─── Browser Automation (optional) ───────────────────────────
# Option A: Browserless.io remote Chromium (no install needed, works in production)
# Get free API key at: https://browserless.io
BROWSERLESS_API_KEY=
# Option B: Self-hosted Browserless WebSocket URL
BROWSERLESS_WS_URL=
# If neither is set, falls back to local Playwright (requires: playwright install chromium)

# ─── GitHub Integration (optional) ──────────────────────────
GITHUB_TOKEN=
# Session "Working directory": paste https://github.com/org/repo → server runs git clone (private: needs token)
# GIT_CLONE_TIMEOUT_SEC=240

# ─── Integrations (optional) ────────────────────────────────
# Slack Events API: POST https://<host>/api/integrations/slack/events — set to verify signatures
# SLACK_SIGNING_SECRET=

# ─── Safety Configuration ───────────────────────────────────
MAX_ITERATIONS=100
MAX_REPAIR_ITERATIONS=3
ALLOW_DEPENDENCY_BUMP=false
MAX_LINES_EDIT=300
MAX_FILES_DELETE=1

# ─── Workspace ──────────────────────────────────────────────
WORKSPACE_DIR=./workspace
RUNS_DIR=./runs
ARTIFACT_DIR=/workspace/runs

# ─── Database (for Docker deployment) ───────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=plodder

# ─── Resource Limits (Docker) ───────────────────────────────
CPU_LIMIT=2.0
MEMORY_LIMIT=4G

# ─── Agent code sandbox (terminal runs in sandbox when enabled) ──
# docker = local Docker (default). e2b = E2B cloud (needs pip extra: poetry install -E sandbox-e2b)
SANDBOX_BACKEND=docker
E2B_API_KEY=
# Optional custom E2B template; empty = default sandbox image
E2B_SANDBOX_TEMPLATE=
# Workspace sync limits for E2B (files uploaded on sandbox start)
# E2B_SYNC_MAX_FILES=400
# E2B_SYNC_MAX_FILE_BYTES=524288
# E2B_SANDBOX_TIMEOUT=600

# ─── IDE / LSP-style diagnostics (Monaco) ───────────────────
# Install: poetry install -E lsp-python  (basedpyright) or put pyright on PATH
# PYRIGHT_CMD=  # optional override, e.g. "basedpyright" or path to pyright
# PYRIGHT_TIMEOUT=90
# TSC_TIMEOUT=120   # npx tsc for .ts/.tsx

# ─── Logging ────────────────────────────────────────────────
VERBOSE=true

# ─── Self-improvement / teacher (optional, OpenAI-first) ────
# After each agent run, call a second model to critique the outcome and append JSONL for later SFT/DPO.
TEACHER_REVIEW_ENABLED=false
TEACHER_BACKEND=openai
TEACHER_MODEL=gpt-4o
# TEACHER_API_KEY=   # optional; defaults to OPENAI_API_KEY
# TRAINING_DATA_LOG_PATH=data/training_logs/reviews.jsonl  # relative to process cwd unless absolute
# TEACHER_MAX_EXCERPT_MESSAGES=32
# TEACHER_MAX_CHARS_PER_MESSAGE=6000

# Training / commercial provenance (not legal advice — align with your counsel + user ToS)
# TRAINING_RIGHTS_BASIS=first_party_mini_devin_sessions_review_with_teacher_model
# TRAINING_COMMERCIAL_OK=true

# ─── Knowledge stack (RAG + prompts; no weight training) ─────
# Optional global corpus: build with scripts/ingest_global_corpus.py — see docs/GLOBAL_CORPUS.md
# GLOBAL_RAG_ENABLED=false
# MINI_DEVIN_GLOBAL_CORPUS_PATH=   # default: ~/.mini-devin/global_corpus/vector_store.json
# GLOBAL_RAG_OPENAI_EMBEDDINGS=false   # set true + OPENAI_API_KEY for OpenAI embeddings on corpus only
# GLOBAL_RAG_TOP_K=8
# GLOBAL_RAG_MAX_CHARS=8000

# Curated few-shot JSONL (default: data/golden/examples.jsonl)
# GOLDEN_DATA_PATH=
# GOLDEN_MAX_RECORDS=8
# GOLDEN_MAX_CHARS=6000

# Append focused rules to system prompt: default | clean_code | performance | security
# AGENT_SPECIALIZATION=default

# ─── Observability (optional; add when you integrate) ───────
# LangSmith (LangChain): LANGCHAIN_TRACING_V2=true, LANGCHAIN_API_KEY=...
# LangFuse: self-host and set keys per their docs

# ─── DigitalOcean App Platform (see .do/app.yaml) ─────────────
# In DO: App → Settings → App-Level Environment Variables (mark secrets as ENCRYPTED).
# Required for default models:
#   OPENAI_API_KEY
# Recommended / optional:
#   LLM_MODEL=gpt-4o-mini
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db   (or leave sqlite for single-instance)
#   BROWSERLESS_API_KEY, BROWSERLESS_WS_URL
#   GITHUB_TOKEN
#   ANTHROPIC_API_KEY, GEMINI_API_KEY or GOOGLE_API_KEY (if you extend app env)
# After deploy, run:  pwsh ./scripts/smoke_deploy.ps1
# Or:  $env:SMOKE_BASE_URL='https://your-app.ondigitalocean.app'; ./scripts/smoke_deploy.ps1

# ─── Self-hosted container / VPS notes ─────────
# If your platform injects PORT, the app will respect it automatically.
# Recommended for stable deploys:
#   PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
#   GIT_PYTHON_REFRESH=quiet
#   PYTHONIOENCODING=UTF-8
#   RUN_MODE=browse
#   LLM_TEMPERATURE=0.1
# Browser Live Preview for containerized shells:
#   set USE_PROCESS_EXECUTION_SANDBOX=1 if you want the agent terminal on the
#   host network so live_preview probe can see localhost. Isolated docker-only shells cannot see dev ports.
# Optional — production auth (same value across restarts / replicas):
#   JWT_SECRET=<long random string>   (Secret)
# Optional — Postgres:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
#   PLODDER_AGENT_WORKSPACE_ROOT=/data/agent-workspaces
#   DATABASE_SSL_REQUIRE=1
#   DATABASE_CONNECT_TIMEOUT=15
#   DATABASE_INIT_TIMEOUT=120   seconds cap for first-time create_all during background startup
#   SKIP_ALEMBIC_UPGRADE=1   emergency only: skip ``alembic upgrade head`` before uvicorn (bootstrap.py)
#   ALEMBIC_UPGRADE_TIMEOUT=300   seconds for migration step (default 300)
#   VERIFICATION_BLOCKING_LINT=1   Auto-verify: treat lint failure as blocking (default: WARNING — no rollback on lint only)
# Optional — browser tools without local Chromium in the container:
#   BROWSERLESS_API_KEY   (Secret)   or   BROWSERLESS_WS_URL=wss://...
# Optional — GitHub repos / API:
#   GITHUB_TOKEN   (Secret)
# Other providers (only if you use them):
#   ANTHROPIC_API_KEY, GEMINI_API_KEY or GOOGLE_API_KEY, AZURE_* , OLLAMA_*
# Search in agent browser tools:
#   TAVILY_API_KEY or SERPAPI_API_KEY
# E2B cloud sandbox (poetry install -E sandbox-e2b):
#   E2B_API_KEY

# ─── Project memory: ingest whole repo into long-term context (optional) ───────
# POST /api/projects/{project_id}/ingest-repo  JSON examples:
#   {"repo_path":"/abs/path/on/server"}  or  {"repo_url":"https://github.com/org/repo.git"}
#   Preview only: add "dry_run": true  |  Same snapshot twice skipped unless "skip_if_duplicate": false
#   optional "keep_clone": true after URL clone
# Paths must be under ../agent-workspace (session clones), this checkout, or:
# REPO_INGEST_EXTRA_ROOT=
# Create sessions with the same project_id to inject that memory into the agent.

# ─── Local bridge (optional — run agent terminal on the developer's machine) ──
# Server: set a long random secret. Mint token: POST /api/sessions/{id}/bridge/token
#   with header X-Plodder-Bridge-Secret: <same value> (legacy: X-MiniDevin-Bridge-Secret).
#   Client: poetry run plodder ...  or  poetry run python -m mini_devin.bridge.local_runner
#   --api-base https://your-host/app/api --session-id <uuid> --secret <same>
# Treat BRIDGE_ISSUE_SECRET like a password — anyone with it can attach a bridge to any session.
# BRIDGE_ISSUE_SECRET=
